# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ems_dev

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for storing platform OAuth tokens)
ENCRYPTION_KEY=32-byte-hex-string-change-in-prod

# App
API_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Shopee
SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key
SHOPEE_REDIRECT_URI=http://localhost:3001/api/v1/shops/shopee/callback
SHOPEE_ENV=test

# TikTok Shop
TIKTOK_APP_KEY=your_app_key
TIKTOK_APP_SECRET=your_app_secret
TIKTOK_REDIRECT_URI=http://localhost:3001/api/v1/shops/tiktok/callback

# Frontend (set in Vercel dashboard for production)
# VITE_API_URL=https://your-api.railway.app
