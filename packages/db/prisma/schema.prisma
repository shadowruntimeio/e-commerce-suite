generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Platform {
  SHOPEE
  TIKTOK
  LAZADA
  AMAZON
  MANUAL
}

enum UserRole {
  ADMIN
  WAREHOUSE_STAFF
  MERCHANT
}

enum Capability {
  ORDER_VIEW
  ORDER_PROCESS // 打单、改物流、标记发货
  ORDER_CANCEL
  INVENTORY_VIEW
  INVENTORY_ADJUST
  PO_APPROVE
  RETURN_INTAKE
}

enum MerchantConfirmStatus {
  PENDING_CONFIRM
  CONFIRMED
  AUTO_CONFIRMED
  CANCELLED_BY_MERCHANT
}

enum ManualOrderStatus {
  PENDING
  SHIPPED
}

enum ReturnCondition {
  PENDING_INSPECTION
  SELLABLE
  DAMAGED
  DISPOSED
}

// Mirrors TikTok V202309 order statuses 1:1. The legacy bucket values
// (PENDING, TO_SHIP, SHIPPED) are kept so the schema is backwards-compatible
// and the UI can still group statuses into broader tabs.
enum OrderStatus {
  UNPAID
  PENDING
  ON_HOLD
  AWAITING_SHIPMENT
  AWAITING_COLLECTION
  PARTIALLY_SHIPPING
  TO_SHIP
  IN_TRANSIT
  DELIVERED
  SHIPPED
  COMPLETED
  CANCELLED
  AFTER_SALES
  EXCEPTION
}

enum InventoryEventType {
  INBOUND
  OUTBOUND
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  RESERVED
  UNRESERVED
  RETURN
}

enum WarehouseType {
  LOCAL
  OVERSEAS
  THREE_PL
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AfterSalesType {
  RETURN
  REFUND
  EXCHANGE
  DISPUTE
}

enum ShopStatus {
  ACTIVE
  INACTIVE
  AUTH_EXPIRED
}

enum AdjustmentReason {
  STOCKTAKE_CORRECTION
  DAMAGE
  LOSS
  EXPIRY
  FOUND
  SYSTEM_ERROR
  OTHER
}

// ─── Tenant & Identity ────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  shops                 Shop[]
  warehouses            Warehouse[]
  systemProducts        SystemProduct[]
  productCategories     ProductCategory[]
  orders                Order[]
  purchaseOrders        PurchaseOrder[]
  suppliers             Supplier[]
  inventoryEvents       InventoryEvent[]
  orderRules            OrderRule[]
  restockingSuggestions RestockingSuggestion[]
  auditLogs             AuditLog[]
  inboundShipments      InboundShipment[]
  notifications         MerchantNotification[]
  chatSessions          ChatSession[]
  bugReports            BugReport[]
  aiTasks               AiTask[]

  @@map("tenants")
}

model User {
  id              String       @id @default(cuid())
  tenantId        String
  email           String
  passwordHash    String
  name            String
  role            UserRole     @default(WAREHOUSE_STAFF)
  capabilities    Capability[] @default([]) // only meaningful for WAREHOUSE_STAFF
  warehouseScope  String[]     @default([]) // warehouseId[]; empty = all warehouses
  createdByUserId String?
  settings        Json         @default("{}") // for MERCHANT: { autoConfirmHours: 12 }
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant              Tenant                 @relation(fields: [tenantId], references: [id])
  refreshTokens       RefreshToken[]
  approvalActions     PoApprovalAction[]
  createdBy           User?                  @relation("UserCreator", fields: [createdByUserId], references: [id])
  createdUsers        User[]                 @relation("UserCreator")
  ownedShops          Shop[]                 @relation("ShopOwner")
  ownedProducts       SystemProduct[]        @relation("ProductOwner")
  ownedWarehouseSkus  WarehouseSku[]         @relation("WhSkuOwner")
  auditLogs           AuditLog[]
  ownedShipments      InboundShipment[]      @relation("ShipmentOwner")
  reviewedShipments   InboundShipment[]      @relation("ShipmentReviewer")
  notifications       MerchantNotification[] @relation("UserNotifications")
  createdManualOrders Order[]                @relation("ManualOrderCreator")
  replacedOrderItems  OrderItem[]            @relation("OrderItemSkuReplacer")
  chatSessions        ChatSession[]
  bugReports          BugReport[]

  @@unique([tenantId, email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Shops (Platform Connections) ────────────────────────────────────────────

model Shop {
  id                   String     @id @default(cuid())
  tenantId             String
  ownerUserId          String // MERCHANT user
  platform             Platform
  externalShopId       String
  name                 String
  status               ShopStatus @default(ACTIVE)
  credentialsEncrypted Json       @default("{}") // AES-256-GCM encrypted tokens
  tokenExpiresAt       DateTime?
  lastSyncAt           DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  owner          User            @relation("ShopOwner", fields: [ownerUserId], references: [id])
  onlineProducts OnlineProduct[]
  orders         Order[]
  shopMessages   ShopMessage[]
  messageThreads MessageThread[]

  @@unique([tenantId, platform, externalShopId])
  @@index([ownerUserId])
  @@map("shops")
}

// ─── Product Catalog (3-tier) ─────────────────────────────────────────────────

model ProductCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products SystemProduct[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_categories")
}

model SystemProduct {
  id          String   @id @default(cuid())
  tenantId    String
  ownerUserId String // MERCHANT user
  spuCode     String
  name        String
  categoryId  String?
  brand       String?
  weightG     Int?
  dimensions  Json? // { length, width, height, unit }
  images      Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  owner    User             @relation("ProductOwner", fields: [ownerUserId], references: [id])
  category ProductCategory? @relation(fields: [categoryId], references: [id])
  skus     SystemSku[]

  @@unique([ownerUserId, spuCode])
  @@index([tenantId])
  @@map("system_products")
}

model SystemSku {
  id              String   @id @default(cuid())
  systemProductId String
  skuCode         String
  attributes      Json     @default("{}") // { color: "red", size: "XL" }
  costPrice       Decimal  @default(0) @db.Decimal(12, 4)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  systemProduct         SystemProduct          @relation(fields: [systemProductId], references: [id])
  onlineSkus            OnlineSku[]
  warehouseSkus         WarehouseSku[]
  orderItems            OrderItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  restockingSuggestions RestockingSuggestion[]
  inboundShipmentItems  InboundShipmentItem[]

  @@unique([systemProductId, skuCode])
  @@map("system_skus")
}

model OnlineProduct {
  id              String    @id @default(cuid())
  shopId          String
  systemProductId String?
  platformItemId  String
  title           String
  status          String
  platformData    Json      @default("{}")
  syncedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shop       Shop        @relation(fields: [shopId], references: [id])
  onlineSkus OnlineSku[]

  @@unique([shopId, platformItemId])
  @@map("online_products")
}

model OnlineSku {
  id               String   @id @default(cuid())
  onlineProductId  String
  systemSkuId      String?
  platformSkuId    String
  price            Decimal  @db.Decimal(12, 4)
  stockSyncEnabled Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  onlineProduct OnlineProduct @relation(fields: [onlineProductId], references: [id])
  systemSku     SystemSku?    @relation(fields: [systemSkuId], references: [id])
  orderItems    OrderItem[]

  @@unique([onlineProductId, platformSkuId])
  @@map("online_skus")
}

// ─── Warehouse & Inventory ────────────────────────────────────────────────────

model Warehouse {
  id                   String        @id @default(cuid())
  tenantId             String
  name                 String
  type                 WarehouseType @default(LOCAL)
  address              Json?
  isDefault            Boolean       @default(false)
  isActive             Boolean       @default(true)
  // Map to external platforms' warehouse IDs, e.g.
  // { "TIKTOK": ["7540272170501474069"], "SHOPEE": [...] }
  platformWarehouseIds Json          @default("{}")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  warehouseSkus      WarehouseSku[]
  inventoryEvents    InventoryEvent[]
  inventorySnapshots InventorySnapshot[]
  inboundOrders      InboundOrder[]
  inboundShipments   InboundShipment[]
  purchaseOrders     PurchaseOrder[]
  outboundWaves      OutboundWave[]
  firstLegShipments  FirstLegShipment[]

  @@map("warehouses")
}

model WarehouseSku {
  id               String   @id @default(cuid())
  systemSkuId      String
  warehouseId      String
  ownerUserId      String // MERCHANT user (denormalized from SystemProduct for query speed)
  barcode          String?
  reorderPoint     Int      @default(0)
  safetyStockDays  Int      @default(14)
  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  systemSku             SystemSku              @relation(fields: [systemSkuId], references: [id])
  warehouse             Warehouse              @relation(fields: [warehouseId], references: [id])
  owner                 User                   @relation("WhSkuOwner", fields: [ownerUserId], references: [id])
  inventoryEvents       InventoryEvent[]
  inventorySnapshots    InventorySnapshot[]
  restockingSuggestions RestockingSuggestion[]

  @@unique([systemSkuId, warehouseId])
  @@index([ownerUserId, warehouseId])
  @@map("warehouse_skus")
}

// Append-only inventory ledger — NEVER update, only insert
model InventoryEvent {
  id             String             @id @default(cuid())
  tenantId       String
  warehouseSkuId String
  warehouseId    String
  eventType      InventoryEventType
  quantityDelta  Int
  reason         AdjustmentReason? // required when eventType = ADJUSTMENT (enforced in app layer)
  referenceType  String? // "order", "purchase_order", "adjustment", etc.
  referenceId    String?
  notes          String?
  createdAt      DateTime           @default(now())
  createdBy      String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  warehouseSku WarehouseSku @relation(fields: [warehouseSkuId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])

  @@index([warehouseSkuId, createdAt])
  @@index([tenantId, createdAt])
  @@map("inventory_events")
}

model InventorySnapshot {
  id                String   @id @default(cuid())
  warehouseSkuId    String
  warehouseId       String
  quantityOnHand    Int      @default(0)
  quantityReserved  Int      @default(0)
  quantityAvailable Int      @default(0)
  snapshotAt        DateTime @default(now())

  warehouseSku WarehouseSku @relation(fields: [warehouseSkuId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])

  @@index([warehouseSkuId, snapshotAt(sort: Desc)])
  @@map("inventory_snapshots")
}

model InboundOrder {
  id              String    @id @default(cuid())
  tenantId        String
  warehouseId     String
  purchaseOrderId String?
  status          String    @default("PENDING")
  trackingNumber  String?
  arrivedAt       DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@map("inbound_orders")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                 String      @id @default(cuid())
  tenantId           String
  shopId             String? // null for manual orders
  platformOrderId    String
  status             OrderStatus @default(PENDING)
  buyerName          String?
  buyerPhone         String?
  shippingAddress    Json?
  currency           String      @default("USD")
  subtotal           Decimal     @default(0) @db.Decimal(12, 4)
  platformDiscount   Decimal     @default(0) @db.Decimal(12, 4)
  sellerDiscount     Decimal     @default(0) @db.Decimal(12, 4)
  shippingFeeBuyer   Decimal     @default(0) @db.Decimal(12, 4)
  shippingFeeSeller  Decimal     @default(0) @db.Decimal(12, 4)
  platformCommission Decimal     @default(0) @db.Decimal(12, 4)
  totalRevenue       Decimal     @default(0) @db.Decimal(12, 4)
  platformMetadata   Json        @default("{}") // raw platform response
  tags               String[]    @default([])
  // Denormalized: first line item's seller_sku. Populated on sync so the
  // order list can be sorted by SKU at the DB level without joining items.
  firstSellerSku     String?
  platformCreatedAt  DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Merchant confirmation gate: incoming orders default to PENDING_CONFIRM and
  // are not visible to warehouse until merchant confirms (or auto-confirm timer fires).
  merchantConfirmStatus    MerchantConfirmStatus @default(PENDING_CONFIRM)
  merchantConfirmedAt      DateTime?
  merchantConfirmExpiresAt DateTime?

  // Manual order fields (isManual=true means this was created by a merchant, not synced from a platform)
  isManual             Boolean            @default(false)
  manualStatus         ManualOrderStatus?
  createdByUserId      String? // merchant who created the manual order
  // Carrier tracking number captured at warehouse ship time. Only meaningful
  // for manual orders — platform orders carry tracking via platformMetadata.
  manualTrackingNumber String?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  shop              Shop?              @relation(fields: [shopId], references: [id])
  createdBy         User?              @relation("ManualOrderCreator", fields: [createdByUserId], references: [id])
  items             OrderItem[]
  afterSalesTickets AfterSalesTicket[]
  waveItems         OutboundWaveItem[]
  manualImages      ManualOrderImage[]
  settlement        OrderSettlement?

  @@unique([shopId, platformOrderId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, firstSellerSku])
  @@index([tenantId, isManual])
  @@index([merchantConfirmStatus, merchantConfirmExpiresAt])
  @@map("orders")
}

// Per-SKU product cost entered by a merchant, keyed by the seller's SKU code
// (the same code that arrives on order line items as sellerSku). Decoupled from
// the SystemProduct catalog so a merchant can set costs for exactly the SKUs
// that appear in their orders. The profit report reads this live (by sellerSku)
// to compute COGS, so an edited cost takes effect immediately — including for
// historical orders — without re-syncing or snapshotting.
model SkuCost {
  id          String   @id @default(cuid())
  tenantId    String
  ownerUserId String // MERCHANT who owns this cost row
  skuCode     String // matches OrderItem.sellerSku
  cost        Decimal  @default(0) @db.Decimal(12, 4)
  currency    String   @default("USD")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerUserId, skuCode])
  @@index([tenantId])
  @@map("sku_costs")
}

// Settlement / transaction-detail data pulled from the TikTok Shop Finance API
// (GET /finance/202309/orders/{order_id}/statement_transactions). One row per
// order, holding the net of its statement transactions (an order may have an
// original settlement plus refund adjustments — we sum them). `raw` keeps the
// full API payload so columns we don't surface yet can be derived later without
// a re-sync. Populated by the settlement sync worker once a settle-able order
// (delivered/completed) appears in a statement; absent until then.
model OrderSettlement {
  id                       String   @id @default(cuid())
  tenantId                 String
  orderId                  String   @unique
  currency                 String   @default("USD")
  // Headline figures
  settlementAmount         Decimal  @default(0) @db.Decimal(14, 4)
  revenueAmount            Decimal  @default(0) @db.Decimal(14, 4)
  feeAmount                Decimal  @default(0) @db.Decimal(14, 4)
  adjustmentAmount         Decimal  @default(0) @db.Decimal(14, 4)
  // Revenue breakdown
  grossSalesAmount         Decimal  @default(0) @db.Decimal(14, 4)
  afterDiscountSubtotal    Decimal  @default(0) @db.Decimal(14, 4)
  sellerDiscountAmount     Decimal  @default(0) @db.Decimal(14, 4)
  platformDiscountAmount   Decimal  @default(0) @db.Decimal(14, 4)
  customerPaymentAmount    Decimal  @default(0) @db.Decimal(14, 4)
  customerPaidShippingFee  Decimal  @default(0) @db.Decimal(14, 4)
  // Fee breakdown
  platformCommissionAmount Decimal  @default(0) @db.Decimal(14, 4)
  referralFeeAmount        Decimal  @default(0) @db.Decimal(14, 4)
  transactionFeeAmount     Decimal  @default(0) @db.Decimal(14, 4)
  affiliateCommission      Decimal  @default(0) @db.Decimal(14, 4)
  affiliateCommissionBeforePit Decimal @default(0) @db.Decimal(14, 4)
  affiliatePartnerCommission   Decimal @default(0) @db.Decimal(14, 4)
  refundAdminFeeAmount     Decimal  @default(0) @db.Decimal(14, 4)
  shippingFeeAmount        Decimal  @default(0) @db.Decimal(14, 4)
  salesTaxAmount           Decimal  @default(0) @db.Decimal(14, 4)
  // Provenance
  statementId              String?
  statementTime            DateTime?
  raw                      Json     @default("{}")
  syncedAt                 DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("order_settlements")
}

// Photos of product parts attached to a manual order's notes by the merchant
// at creation time. Stored inline (like BugReportImage) — max 3 per order,
// 2MB each, so the worst case per order is bounded at 6MB.
model ManualOrderImage {
  id        String   @id @default(cuid())
  orderId   String
  mimeType  String
  sizeBytes Int
  data      Bytes
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("manual_order_images")
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  onlineSkuId      String?
  systemSkuId      String?
  platformSkuId    String
  sellerSku        String? // seller-defined SKU code (e.g. D-1-2); used in picking
  productName      String
  skuName          String?
  quantity         Int
  unitPrice        Decimal @db.Decimal(12, 4)
  discount         Decimal @default(0) @db.Decimal(12, 4)
  costPriceAtOrder Decimal @default(0) @db.Decimal(12, 4)

  // SKU replacement audit. When a merchant swaps an item's SKU (out-of-stock
  // workaround), the live fields above point at the NEW SKU and the original
  // values are snapshotted here so the warehouse can render an old→new diff
  // and the shipping label can be stamped with the replacement. Set once on
  // the first replacement; subsequent replacements update the live fields but
  // keep the original-snapshot intact.
  originalSellerSku   String?
  originalSystemSkuId String?
  originalSkuName     String?
  originalProductName String?
  replacedAt          DateTime?
  replacedByUserId    String?

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  onlineSku  OnlineSku? @relation(fields: [onlineSkuId], references: [id])
  systemSku  SystemSku? @relation(fields: [systemSkuId], references: [id])
  replacedBy User?      @relation("OrderItemSkuReplacer", fields: [replacedByUserId], references: [id])

  @@map("order_items")
}

model OrderRule {
  id         String   @id @default(cuid())
  tenantId   String
  shopId     String?
  name       String
  priority   Int      @default(0)
  conditions Json // { operator: "AND", rules: [...] }
  actions    Json // [{ type: "assign_warehouse", value: "..." }, ...]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("order_rules")
}

// Single source of truth split: platform fields mirror TikTok's return state
// (we don't transform them); warehouse fields track the physical flow that
// TikTok doesn't know about. Lifecycle is implied: REQUEST_PENDING from TK
// = merchant needs to approve; warehouse acts once goods physically arrive.
model AfterSalesTicket {
  id                   String          @id @default(cuid())
  orderId              String
  type                 AfterSalesType
  platformReturnId     String? // TikTok return_id, unique per shop
  platformReturnStatus String? // mirrors TK enum
  platformPayload      Json            @default("{}") // raw last-seen TK payload, for debugging
  nextSellerActions    String[]        @default([]) // TK's seller_next_action_response[].action — drives routing
  notes                String?
  expectedQty          Int? // qty platform claims is being returned
  returnedQty          Int? // qty actually received at warehouse
  condition            ReturnCondition @default(PENDING_INSPECTION)
  warehouseSkuId       String? // populated on SELLABLE intake
  arrivedAt            DateTime?
  inspectedAt          DateTime?
  inspectedByUserId    String?
  restockedAt          DateTime? // when SELLABLE was written back to inventory
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@unique([orderId])
  @@unique([platformReturnId])
  @@index([platformReturnStatus])
  @@map("after_sales_tickets")
}

// ─── Wave Outbound ────────────────────────────────────────────────────────────

model OutboundWave {
  id          String   @id @default(cuid())
  tenantId    String
  warehouseId String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  createdBy   String?

  warehouse Warehouse          @relation(fields: [warehouseId], references: [id])
  items     OutboundWaveItem[]

  @@map("outbound_waves")
}

model OutboundWaveItem {
  id      String @id @default(cuid())
  waveId  String
  orderId String
  status  String @default("PENDING")

  wave  OutboundWave @relation(fields: [waveId], references: [id])
  order Order        @relation(fields: [orderId], references: [id])

  @@map("outbound_wave_items")
}

// ─── Purchase & Supplier ──────────────────────────────────────────────────────

model Supplier {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  platform           Platform @default(MANUAL)
  externalSupplierId String?
  contact            Json?
  paymentTerms       String?
  leadTimeDays       Int      @default(7)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    String
  supplierId  String
  warehouseId String
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @db.Decimal(12, 4)
  currency    String              @default("USD")
  eta         DateTime?
  notes       String?
  createdBy   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id])
  items           PurchaseOrderItem[]
  approvalActions PoApprovalAction[]
  inboundOrders   InboundOrder[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  systemSkuId      String
  quantityOrdered  Int
  quantityReceived Int     @default(0)
  unitCost         Decimal @db.Decimal(12, 4)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  systemSku     SystemSku     @relation(fields: [systemSkuId], references: [id])

  @@map("purchase_order_items")
}

model PoApprovalAction {
  id              String    @id @default(cuid())
  purchaseOrderId String
  stepNumber      Int
  approverUserId  String
  status          String    @default("PENDING")
  comment         String?
  actedAt         DateTime?
  createdAt       DateTime  @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  approver      User          @relation(fields: [approverUserId], references: [id])

  @@map("po_approval_actions")
}

model RestockingSuggestion {
  id             String   @id @default(cuid())
  tenantId       String
  warehouseSkuId String
  systemSkuId    String
  suggestedQty   Int
  reason         Json     @default("{}")
  expiresAt      DateTime
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  warehouseSku WarehouseSku @relation(fields: [warehouseSkuId], references: [id])
  systemSku    SystemSku    @relation(fields: [systemSkuId], references: [id])

  @@map("restocking_suggestions")
}

// ─── Analytics / ETL ─────────────────────────────────────────────────────────

model SalesFact {
  id                 String   @id @default(cuid())
  tenantId           String
  date               DateTime @db.Date
  shopId             String
  systemSkuId        String?
  ordersCount        Int      @default(0)
  unitsSold          Int      @default(0)
  grossRevenue       Decimal  @default(0) @db.Decimal(14, 4)
  platformCommission Decimal  @default(0) @db.Decimal(14, 4)
  shippingCost       Decimal  @default(0) @db.Decimal(14, 4)
  cogs               Decimal  @default(0) @db.Decimal(14, 4)
  profit             Decimal  @default(0) @db.Decimal(14, 4)

  @@unique([tenantId, date, shopId, systemSkuId])
  @@index([tenantId, date])
  @@map("sales_facts")
}

model InventoryDailySnapshot {
  id             String   @id @default(cuid())
  tenantId       String
  date           DateTime @db.Date
  warehouseSkuId String
  warehouseId    String
  quantityOnHand Int      @default(0)
  inventoryValue Decimal  @default(0) @db.Decimal(14, 4)
  daysOfStock    Decimal  @default(0) @db.Decimal(8, 2)

  @@unique([tenantId, date, warehouseSkuId])
  @@index([tenantId, date])
  @@map("inventory_daily_snapshots")
}

model AdSpendFact {
  id                String   @id @default(cuid())
  tenantId          String
  date              DateTime @db.Date
  shopId            String
  platform          Platform
  campaignId        String
  campaignName      String?
  impressions       Int      @default(0)
  clicks            Int      @default(0)
  spend             Decimal  @default(0) @db.Decimal(14, 4)
  revenueAttributed Decimal  @default(0) @db.Decimal(14, 4)
  roas              Decimal  @default(0) @db.Decimal(8, 4)

  @@unique([tenantId, date, shopId, campaignId])
  @@index([tenantId, date])
  @@map("ad_spend_facts")
}

// ─── Customer Service Inbox ───────────────────────────────────────────────────

model ShopMessage {
  id                String   @id @default(cuid())
  tenantId          String
  shopId            String
  platformThreadId  String
  platformMsgId     String
  senderType        String // "buyer" | "seller"
  senderName        String?
  content           String
  messageType       String   @default("text") // "text" | "image" | "order"
  isRead            Boolean  @default(false)
  tags              String[] @default([])
  platformMetadata  Json     @default("{}")
  platformCreatedAt DateTime
  createdAt         DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, platformMsgId])
  @@index([tenantId, isRead])
  @@index([tenantId, platformThreadId])
  @@map("shop_messages")
}

model MessageThread {
  id                 String   @id @default(cuid())
  tenantId           String
  shopId             String
  platformThreadId   String
  buyerName          String?
  buyerPlatformId    String?
  lastMessageAt      DateTime
  lastMessagePreview String?
  isRead             Boolean  @default(false)
  tags               String[] @default([])
  orderId            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, platformThreadId])
  @@index([tenantId, isRead, lastMessageAt])
  @@map("message_threads")
}

// ─── Logistics ────────────────────────────────────────────────────────────────

model FirstLegShipment {
  id               String    @id @default(cuid())
  tenantId         String
  warehouseId      String
  trackingNumber   String?
  carrier          String?
  shipmentType     String    @default("SEA") // SEA | AIR | RAIL
  originWarehouse  String?
  destination      String?
  departedAt       DateTime?
  estimatedArrival DateTime?
  status           String    @default("PENDING") // PENDING | IN_TRANSIT | ARRIVED | CLEARED
  weightKg         Decimal?  @db.Decimal(10, 3)
  volumeCbm        Decimal?  @db.Decimal(10, 4)
  cost             Decimal?  @db.Decimal(14, 4)
  currency         String    @default("USD")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, status])
  @@map("first_leg_shipments")
}

// ─── Merchant inbound shipments ────────────────────────────────────────────
// A MERCHANT submits inventory through an Inbound Shipment: they upload an
// Excel of SKU + qty, fill in carrier/tracking + ship date, submit. The
// shipment lands in PENDING_REVIEW. Warehouse staff confirm on arrival,
// optionally adjusting per-SKU quantities. Inventory is only written when
// a shipment is CONFIRMED. WAREHOUSE_STAFF / ADMIN keep the direct-write
// import path (no shipment created).

enum InboundShipmentStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

model InboundShipment {
  id               String                @id @default(cuid())
  tenantId         String
  ownerUserId      String // submitting merchant
  warehouseId      String // destination warehouse
  status           InboundShipmentStatus @default(PENDING_REVIEW)
  shippedAt        DateTime // 货物发出日期
  carrier          String // 快递公司
  trackingNumber   String // 快递单号
  notes            String?
  rejectReason     String?
  submittedAt      DateTime              @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?

  tenant    Tenant                @relation(fields: [tenantId], references: [id])
  owner     User                  @relation("ShipmentOwner", fields: [ownerUserId], references: [id])
  warehouse Warehouse             @relation(fields: [warehouseId], references: [id])
  reviewer  User?                 @relation("ShipmentReviewer", fields: [reviewedByUserId], references: [id])
  items     InboundShipmentItem[]

  @@index([tenantId, status, submittedAt(sort: Desc)])
  @@index([ownerUserId, submittedAt(sort: Desc)])
  @@map("inbound_shipments")
}

model InboundShipmentItem {
  id                String   @id @default(cuid())
  inboundShipmentId String
  systemSkuId       String
  expectedQuantity  Int // merchant's claim
  confirmedQuantity Int? // warehouse's actual count, set on confirm
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shipment  InboundShipment @relation(fields: [inboundShipmentId], references: [id], onDelete: Cascade)
  systemSku SystemSku       @relation(fields: [systemSkuId], references: [id])

  @@index([inboundShipmentId])
  @@map("inbound_shipment_items")
}

// ─── Merchant notifications ───────────────────────────────────────────────
// Lightweight inbox for events targeted at a specific merchant — first user
// is the SHIPMENT_QUANTITY_ADJUSTED case (warehouse confirmed but with a
// different qty than declared) and SHIPMENT_REJECTED.

enum MerchantNotificationType {
  SHIPMENT_QUANTITY_ADJUSTED
  SHIPMENT_REJECTED
  MANUAL_ORDER_CREATED
  MANUAL_ORDER_SHIPPED
}

model MerchantNotification {
  id        String                   @id @default(cuid())
  tenantId  String
  userId    String // recipient (the merchant)
  type      MerchantNotificationType
  title     String
  body      String?
  payload   Json                     @default("{}")
  readAt    DateTime?
  createdAt DateTime                 @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation("UserNotifications", fields: [userId], references: [id])

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("merchant_notifications")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String? // null = system action (cron, webhook)
  action      String // e.g. "user.create", "order.cancel", "inventory.adjust"
  targetType  String? // "user" | "order" | "warehouse_sku" | ...
  targetId    String?
  payload     Json     @default("{}")
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation(fields: [actorUserId], references: [id])

  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

// ─── AI Customer Support ──────────────────────────────────────────────────────
// In-app chat answered by a local Claude Code worker that polls AiTask. The
// worker has no API key — it uses Eric's claude.ai subscription via the CLI
// in headless mode (--tools "" --no-session-persistence). All AI work flows
// through the AiTask queue so prod (Railway) never needs to reach the worker
// machine directly.

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum BugStatus {
  OPEN // freshly submitted, awaiting triage
  TRIAGING // claimed by /bug-triage skill
  FIXED // a commit references this report
  WONTFIX
  DUPLICATE
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AiTaskStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum AiTaskType {
  CHAT_REPLY // chat session needs an assistant message generated
  BUG_TRIAGE // bug report waiting for autonomous triage (reserved; not wired yet)
}

model ChatSession {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  title     String? // first user message, truncated — populated lazily
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@index([tenantId, userId, updatedAt(sort: Desc)])
  @@map("chat_sessions")
}

model ChatMessage {
  id           String          @id @default(cuid())
  sessionId    String
  role         ChatMessageRole
  content      String          @db.Text
  // Only meaningful for ASSISTANT rows: result of scope-check pass.
  // inScope=false carries the canned refusal copy in `content`. suggestBug=true
  // is the model's hint to UI that the user should switch to the bug tab.
  inScope      Boolean?
  suggestBug   Boolean?
  // Pointer to the AiTask that produced this assistant row (null for USER and
  // for assistant rows manually inserted by the triage skill).
  aiTaskId     String?         @unique
  errorReason  String? // populated when assistant row represents a worker failure
  tokensInput  Int?
  tokensOutput Int?
  latencyMs    Int?
  // Image attachment metadata. Bytes are NOT persisted server-side — they
  // live only inside AiTask.payload long enough for the worker to consume,
  // then get nulled out on DONE. We keep the metadata so we can (a) enforce
  // a 20-image-per-user-per-day quota and (b) render a placeholder in the
  // UI after a page reload (the browser only holds the blob URL for the
  // current session).
  attachmentMimeType  String?
  attachmentSizeBytes Int?
  createdAt    DateTime        @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  aiTask  AiTask?     @relation("AiTaskReply", fields: [aiTaskId], references: [id])

  @@index([sessionId, createdAt])
  // Daily image quota lookup needs a fast filter on attachmentMimeType +
  // createdAt; userId is derived through session join.
  @@index([createdAt])
  @@map("chat_messages")
}

model BugReport {
  id            String      @id @default(cuid())
  tenantId      String
  userId        String // reporter
  shopId        String? // contextual when relevant
  status        BugStatus   @default(OPEN)
  severity      BugSeverity @default(MEDIUM)
  summary       String // one-liner from user
  description   String?     @db.Text // long-form details
  route         String? // window.location.href at the time of report
  consoleErrors Json? // ring-buffer snapshot from the browser
  userAgent     String?
  emsCommitSha  String? // build-time injected so we know what code shipped
  metadata      Json? // free-form: orderId/skuCode/shopName/etc.

  // /bug-triage skill writes these on each pass.
  claudeNotes  String?   @db.Text // analysis text from Claude Code
  fixCommitSha String? // populated when status moves to FIXED
  triagedAt    DateTime?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  user   User              @relation(fields: [userId], references: [id])
  images BugReportImage[]

  @@index([tenantId, status, createdAt])
  @@index([status, severity, createdAt]) // worker queue scan
  // For the hourly image-cleanup sweep — find FIXED/WONTFIX/DUPLICATE bugs
  // whose images can be released.
  @@index([status, resolvedAt])
  @@map("bug_reports")
}

// One-to-many images attached to a BugReport (max 2 enforced at the API).
// Bytes are persisted, unlike chat attachments, because the dev workflow
// needs them while the bug is open. They get auto-deleted by a scheduled
// sweep once the bug has been FIXED / WONTFIX / DUPLICATE for ≥ 7 days
// (see apps/api/src/workers/scheduler.ts).
model BugReportImage {
  id           String   @id @default(cuid())
  bugReportId  String
  mimeType     String
  sizeBytes    Int
  data         Bytes
  createdAt    DateTime @default(now())

  bugReport BugReport @relation(fields: [bugReportId], references: [id], onDelete: Cascade)

  @@index([bugReportId])
  @@map("bug_report_images")
}

model AiTask {
  id          String       @id @default(cuid())
  tenantId    String // for monitoring + per-tenant rate limits
  taskType    AiTaskType
  status      AiTaskStatus @default(PENDING)
  payload     Json // task-specific input (sessionId/messageId/etc.)
  result      Json? // parsed model output (in_scope/suggest_bug/answer)
  error       String?
  attempts    Int          @default(0)
  priority    Int          @default(0) // higher first; lets BUG_TRIAGE yield to CHAT_REPLY
  pickedUpAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  chatMessage ChatMessage? @relation("AiTaskReply")

  // The worker pulls via this composite index; FOR UPDATE SKIP LOCKED keeps
  // concurrent workers from grabbing the same row.
  @@index([status, priority(sort: Desc), createdAt])
  @@map("ai_tasks")
}
